GITHUB_USER=your-user
GH_TOKEN= GitHub → Settings → Developer settings → Personal access tokens → Fine-grained tokens
  - issues: read & write
  - pull requests: read & write
  - contents: read & write
# ANTHROPIC_API_KEY não é necessário com Team Plan do claude.ai.
# Autenticação: make enter → claude → /login (OAuth). Token salvo no volume Docker "claude-config".
# Se preferir API key (requer conta em console.anthropic.com, cobrada por token): descomente abaixo.
# ANTHROPIC_API_KEY=your_key_here
OPENAI_API_KEY=
WORKSPACE=/workspace